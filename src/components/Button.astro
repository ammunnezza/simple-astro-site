---
interface Props {
  href?: string;           // Se c'è un link, diventa un tag <a>, altrimenti un <button>
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;          // Per aggiungere classi extra al volo
  id?: string;
  type?: "button" | "submit" | "reset";
}

const { 
  href, 
  variant = 'primary', 
  size = 'md', 
  class: className, 
  id,
  type = "button"
} = Astro.props;

// Definiamo gli stili base e le varianti
const baseStyles = "inline-flex items-center justify-center font-bold uppercase tracking-widest transition-all duration-300 active:scale-95 rounded-xl border-2";

const variants = {
  primary: "bg-[#ff6f00] border-[#ff6f00] text-white hover:bg-zinc-900 hover:border-zinc-900 shadow-lg shadow-orange-200",
  secondary: "bg-zinc-900 border-zinc-900 text-white hover:bg-[#ff6f00] hover:border-[#ff6f00] shadow-lg shadow-zinc-200",
  outline: "bg-transparent border-zinc-200 text-zinc-900 hover:border-[#ff6f00] hover:text-[#ff6f00]"
};

const sizes = {
  sm: "px-4 py-2 text-[10px]",
  md: "px-8 py-3 text-xs",
  lg: "px-10 py-4 text-sm"
};

const Element = href ? 'a' : 'button';
---

<Element 
  href={href} 
  id={id}
  type={!href ? type : undefined}
  class:list={[baseStyles, variants[variant], sizes[size], className]}
>
  <slot /> </Element>

