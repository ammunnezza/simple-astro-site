---
interface ParkingLot {
  id: number | string;          // used for P1, P2, P3 badge
  name: string;                 // e.g. "Parking Nord"
  address?: string;             // human-readable address
  coords?: {                    // latitude / longitude
    lat: number;
    lng: number;
  };
  notes?: string;               // e.g. "Open 24h · Free"
  available?: boolean;          // grey out if false
}

interface Props {
  lots: ParkingLot[];
  title?: string;
}

const { lots, title = "Parking" } = Astro.props;

// Build the Google Maps URL — prefer coords, fall back to address
function mapsUrl(lot: ParkingLot): string | null {
  if (lot.coords) {
    return `https://www.google.com/maps/dir/?api=1&destination=${lot.coords.lat},${lot.coords.lng}`;
  }
  if (lot.address) {
    return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(lot.address)}`;
  }
  return null;
}
---

<div class="w-full">

  {title && (
    <h2 class="text-2xl font-bold text-neutral-900 tracking-tight mb-6">{title}</h2>
  )}

  <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {lots.map((lot) => {
      const url = mapsUrl(lot);
      const available = lot.available !== false;

      return (
        <li>
          <a
            href={url ?? undefined}
            target={url ? "_blank" : undefined}
            rel={url ? "noopener noreferrer" : undefined}
            aria-label={`Directions to ${lot.name}`}
            class={[
              "group flex items-start gap-4 p-4 rounded-2xl border transition-all duration-200",
              available
                ? "bg-white border-neutral-200 hover:border-neutral-400 hover:shadow-md cursor-pointer"
                : "bg-neutral-50 border-neutral-100 opacity-50 cursor-not-allowed pointer-events-none",
            ].join(" ")}
          >

            <!-- Road-sign badge: big P + small number -->
            <div
              class={[
                "flex-shrink-0 w-14 h-14 rounded-xl flex flex-col items-center justify-center select-none border-2",
                available
                  ? "bg-[#5303d3] border-[#080808] text-white group-hover:bg-[#ff6f00] transition-colors duration-200"
                  : "bg-neutral-300 border-neutral-400 text-white",
              ].join(" ")}
            >
              <span class="leading-none font-black text-2xl">P</span>
              <span class="leading-none font-bold text-[11px] -mt-0.5 opacity-80">{lot.id}</span>
            </div>

            <!-- Info -->
            <div class="flex flex-col gap-1 min-w-0">
              <span class="font-semibold text-sm text-neutral-900 truncate">{lot.name}</span>

              {lot.address && (
                <span class="text-xs text-neutral-400 leading-snug line-clamp-2">{lot.address}</span>
              )}

              {lot.coords && !lot.address && (
                <span class="text-xs text-neutral-400 font-mono">
                  {lot.coords.lat.toFixed(5)}, {lot.coords.lng.toFixed(5)}
                </span>
              )}

              {lot.notes && (
                <span class="text-xs text-neutral-500 mt-0.5">{lot.notes}</span>
              )}

              {!available && (
                <span class="text-[10px] font-semibold tracking-widest uppercase text-neutral-400 mt-0.5">
                  Unavailable
                </span>
              )}

              {url && available && (
                <span class="inline-flex items-center gap-1 text-[11px] font-medium text-neutral-400 group-hover:text-neutral-700 transition-colors duration-200 mt-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Indicazioni stradali
                </span>
              )}
            </div>

          </a>
        </li>
      );
    })}
  </ul>
</div>