---
interface Props {
  text?: string;
  link?: string;
  color?: string;
  rotation?: string;
}

const { 
  text = "Diventa Partner 2026", 
  link = "/sponsor", 
  color = "bg-[#ff6f00]",
  rotation = "-rotate-3" 
} = Astro.props;
---

<div class="flex justify-center my-12 animate-bounce">
  <a 
    href={link}
    class={`
      ${color} ${rotation}
      group relative inline-block px-8 py-4 
      text-white font-black uppercase tracking-tighter text-2xl md:text-3xl
      shadow-[8px_8px_0px_0px_rgba(0,0,0,0.9)]
      hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,0.9)]
      hover:-translate-y-1 hover:-rotate-1
      transition-all duration-200 cursor-pointer
      border-2 border-black
    `}
  >
    <div class="absolute top-0 left-0 w-full h-1/2 bg-white/10 group-hover:bg-white/20 transition-colors"></div>
    
    <span class="relative z-10 flex items-center gap-3">
      {text}
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-8 h-8 group-hover:translate-x-2 transition-transform">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </span>

    <div class="absolute -bottom-[2px] -right-[2px] w-0 h-0 
      border-t-[20px] border-t-transparent 
      border-r-[20px] border-r-zinc-100/30 
      group-hover:border-r-zinc-100/50 transition-all">
    </div>
  </a>
</div>