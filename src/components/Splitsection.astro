---
import Title from "./Title.astro";

interface Props {
  // Title props — all optional, omit them to skip the title entirely
  title?: string;
  subtitle?: string;
  tag?: string;
  titleAlign?: "left" | "center" | "right";

  // Content
  body?: string;

  // Image
  image: string;
  imageAlt?: string;

  // Layout
  reverse?: boolean;    // image on the right when true

  // CTA
  href?: string;
  cta?: string;
}

const {
  title,
  subtitle,
  tag,
  titleAlign = "left",
  body,
  image,
  imageAlt = "",
  reverse = false,
  href,
  cta = "Learn more",
} = Astro.props;
---

<section class="w-full py-16 sm:py-20">
  <div class={`max-w-7xl mx-auto px-6 lg:px-12 flex flex-col ${reverse ? "md:flex-row-reverse" : "md:flex-row"} items-start gap-12 lg:gap-20`}>

    <!-- Image -->
    <div class="w-full md:w-1/2 flex-shrink-0 md:sticky md:top-24 self-start">
      <div class="rounded-2xl overflow-hidden bg-neutral-100 aspect-[4/3] shadow-sm">
        <img src={image} alt={imageAlt} class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Text -->
    <div class="w-full md:w-1/2 flex flex-col gap-6">

      <!-- Title block — only rendered if title prop is provided -->
      {title && (
        <Title
          title={title}
          subtitle={subtitle}
          tag={tag}
          align={titleAlign}
        />
      )}

      <!-- Optional body prop for short text -->
      {body && (
        <p class="text-base text-neutral-500 leading-relaxed">{body}</p>
      )}

      <!-- Slot for long/rich content -->
      <slot />

      {href && (
        <a
          href={href}
          class="self-start inline-flex items-center gap-2 px-5 py-2.5 rounded-full border-2 border-neutral-900 text-sm font-semibold text-neutral-900 hover:bg-neutral-900 hover:text-white transition-all duration-200 group"
        >
          {cta}
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      )}

    </div>
  </div>
</section>