---
import logoImg from "../assets/logo.png";
import { Image } from "astro:assets";
import Social from "../components/Social.astro";
---

<div class="navbar bg-black text-white shadow-sm sticky top-0 z-50">
  <div class="navbar-start">
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost lg:hidden hover:text-orange-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
      </div>
      <ul id="mobile-menu" tabindex="-1" class="menu menu-sm dropdown-content bg-black border border-white/10 rounded-box z-1 mt-3 w-70 p-2 shadow-2xl max-h-[85vh] overflow-y-auto flex-nowrap">
        </ul>
    </div>
      <a
        href="/"
        aria-label="Home"
        class="shrink-0 opacity-90 hover:opacity-100 transition-opacity duration-200"
      >
        <Image
          src={logoImg}
          alt="Gerusco"
          height={40}
          class="h-10 w-auto object-contain"
          loading="eager"
        />
      </a>
  </div>
  
  <div class="navbar-center hidden lg:flex">
    <ul id="desktop-menu" class="menu menu-horizontal px-1 gap-1">
      </ul>
  </div>

  <div class="navbar-end">
      <Social color="text-white hover:text-orange-600"/>
  </div>
</div>


<script>
  // 1. Definisci qui i tuoi link una volta sola
  const menuItems = [
    { label: 'HOME', href: '/' },
    { 
      label: 'GERUSCO', 
      children: [
        { label: 'Chi Siamo', href: '/chi-siamo' },
        { label: "Soci", href: "/soci" },
        { label: "Sponsor", href: "/sponsorizzazione" },
        { label: "Locations", href: "/locations" },
        { label: "Per il Paese", href: "/per-il-paese" },
      ]
    },    
    
    { 
      label: 'Eventi', 
      children: [
        { label: "RocktoberFest", href: "/rocktoberfest" },
        { label: "Festa del Gerusco", href: "/festa-del-gerusco" },
        { label: "Street Food Festival", href: "/gsff" },
        { label: "Cura & Bea", href: "/curaebea" },
      ]
    },
        { 
      label: 'Ristorante', 
      children: [
        { label: "Menu", href: "/menu" },
        { label: "Prenotazione Tavolo", href: "/prenotazione-tavolo" },
          ]
    },
    {
      label: "Associazione",
      children: [
        { label: "Statuto", href: "/associazione/statuto" },
        { label: "Atto Costitutivo", href: "/associazione/atto_costitutivo" },
        { label: "Verbale 17/07/2019", href: "/associazione/verbale-17-07-19" },
        { label: "Verbale 05/04/2022", href: "/associazione/verbale-05-04-22" },
      ],
    },

    { 
      label: 'Chi Sosteniamo', 
      children: [
        { label: "2025", href: "/chi-sosteniamo/2025" },
        { label: "2024", href: "/chi-sosteniamo/2024" },
        { label: "2023", href: "/chi-sosteniamo/2023" },
      ]
    },
  ];

function renderMenu() {
  const mobileContainer = document.getElementById('mobile-menu');
  const desktopContainer = document.getElementById('desktop-menu');

  // Classi base per i colori e le transizioni
  const colorClasses = "text-white hover:text-orange-500 hover:bg-white/5 focus:text-orange-500 focus:bg-transparent active:bg-orange-500/20 transition-all duration-200 uppercase tracking-wide";
  
  // Classi specifiche per DIMENSIONE (Grande su mobile, normale su desktop)
  const mobileSize = "text-xl py-3"; // Più grande e con più spazio verticale per il pollice
  const desktopSize = "text-base";

  let mobileHTML = '';
  let desktopHTML = '';

  menuItems.forEach(item => {
    if (item.children) {
      const mobileChildren = item.children
        .map(child => `<li><a class="${colorClasses} ${mobileSize}" href="${child.href}">${child.label}</a></li>`)
        .join('');
      
      const desktopChildren = item.children
        .map(child => `<li><a class="${colorClasses} ${desktopSize}" href="${child.href}">${child.label}</a></li>`)
        .join('');

      // MOBILE (Accordion)
      mobileHTML += `
        <li>
          <details class="mobile-details border-b border-white/5">
            <summary class="${colorClasses} ${mobileSize} font-bold">${item.label}</summary>
            <ul class="before:bg-orange-500/30">${mobileChildren}</ul>
          </details>
        </li>`;
      
      // DESKTOP (Dropdown)
      desktopHTML += `
        <li>
          <details>
            <summary class="${colorClasses} ${desktopSize} font-medium">${item.label}</summary>
            <ul class="p-2 bg-black border border-white/10 w-52 z-1 shadow-2xl">
              ${desktopChildren}
            </ul>
          </details>
        </li>`;
    } else {
      // Link singoli
      mobileHTML += `<li class="border-b border-white/5"><a class="${colorClasses} ${mobileSize}" href="${item.href}">${item.label}</a></li>`;
      desktopHTML += `<li><a class="${colorClasses} ${desktopSize}" href="${item.href}">${item.label}</a></li>`;
    }
  });
  if (mobileContainer) mobileContainer.innerHTML = mobileHTML;
  if (desktopContainer) desktopContainer.innerHTML = desktopHTML;

  setupAccordion();
}

function setupAccordion() {
  // Selezioniamo TUTTI i tag details della navbar (sia mobile che desktop)
  const allDetails = document.querySelectorAll('.navbar details');
  
  allDetails.forEach((targetDetail) => {
    // 1. CHIUSURA QUANDO NE APRI UN ALTRO
    targetDetail.addEventListener('toggle', (e) => {
      // Se stiamo aprendo questo elemento
      if (targetDetail.hasAttribute('open')) {
        allDetails.forEach((detail) => {
          if (detail !== targetDetail) {
            detail.removeAttribute('open');
          }
        });
      }
    });
  });

  // 2. CHIUSURA QUANDO CLICCHI FUORI (SOLO DESKTOP)
  document.addEventListener('click', (e) => {
    allDetails.forEach((detail) => {
      // Se il click è avvenuto fuori dal tag <details> e il menu è aperto
      if (!detail.contains(e.target as Node) && detail.hasAttribute('open')) {
        detail.removeAttribute('open');
      }
    });
  });
}

renderMenu();

  // Esegui la funzione al caricamento
  renderMenu();
</script>