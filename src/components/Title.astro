---
interface Props {
  title?: string;
  subtitle?: string;
  align?: "left" | "center" | "right";
  tag?: string; // optional eyebrow label e.g. "Our Services"
}
 
const { title, subtitle, align = "left", tag } = Astro.props;
 
const alignClass = {
  left:   "items-start text-left",
  center: "items-center text-center",
  right:  "items-end text-right",
}[align];

---

<div class={`flex flex-col gap-3 ${alignClass}`}>
 
  <!-- Eyebrow tag -->
  {tag && (
    <span class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.2em] uppercase text-neutral-400">
      <span class="block w-5 h-px bg-neutral-300"></span>
      {tag}
      <span class="block w-5 h-px bg-neutral-300"></span>
    </span>
  )}
 
  <!-- Title -->
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900 leading-tight tracking-tight">
    {title}
  </h2>
 
  <!-- Accent rule -->
  <div class={`h-[3px] w-12 bg-neutral-900 rounded-full ${align === "center" ? "mx-auto" : align === "right" ? "ml-auto" : ""}`}></div>
 
  <!-- Subtitle -->
  {subtitle && (
    <p class="text-base sm:text-lg text-neutral-500 leading-relaxed max-w-xl">
      {subtitle}
    </p>
  )}
 
</div>