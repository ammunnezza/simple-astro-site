---

import '../styles/global.css';
interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="it" class="bg-brand-bg"> 
	<head>
    	<meta charset="UTF-8" />
    	<meta name="viewport" content="width=device-width" />
    	
		<title>{title}</title>
  </head>
	<body>

		<main class="pt-2 min-h-screen">
			<slot />
		</main>

	</body>
</html>