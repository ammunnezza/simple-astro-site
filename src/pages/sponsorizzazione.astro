---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Sponsorizzazione">
  <div class="min-h-screen bg-zinc-50 text-zinc-900 font-sans pb-20">
    <section class="relative py-20 px-6 bg-white overflow-hidden">
      <div class="max-w-5xl mx-auto text-center relative z-10">
        <h1
          class="text-6xl md:text-9xl font-black uppercase tracking-tighter leading-[0.8] mb-8"
        >
          Gerusco <br />
          <span class="text-zinc-300">Sponsor</span>
        </h1>

        <div class="mt-12 max-w-3xl mx-auto">
          <h2
            class="text-2xl md:text-3xl font-black uppercase tracking-tight text-[#ff6f00] mb-4"
          >
            Perché sponsorizzarci?
          </h2>
          <p class="text-xl leading-relaxed text-zinc-500 font-medium">
            Scegliere di sostenere <span class="text-zinc-900 font-bold"
              >Gerusco</span
            > significa andare oltre l’evento: vuol dire contribuire concretamente
            alla crescita della comunità, rafforzando il legame tra aziende, cittadini
            e territorio.
          </p>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 -mt-8 relative z-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div
          class="card bg-white border border-zinc-200 shadow-sm p-8 hover:border-[#ff6f00] transition-colors"
        >
          <span class="text-3xl mb-4">📈</span>
          <h3 class="font-bold uppercase text-xs tracking-widest mb-2">
            Visibilità
          </h3>
          <p class="text-sm text-zinc-500">
            Aumentare la visibilità del brand a livello locale.
          </p>
        </div>
        <div
          class="card bg-white border border-zinc-200 shadow-sm p-8 hover:border-[#ff6f00] transition-colors"
        >
          <span class="text-3xl mb-4">🤝</span>
          <h3 class="font-bold uppercase text-xs tracking-widest mb-2">
            Valori
          </h3>
          <p class="text-sm text-zinc-500">
            Associare il nome a solidarietà e cultura.
          </p>
        </div>
        <div
          class="card bg-white border border-zinc-200 shadow-sm p-8 hover:border-[#ff6f00] transition-colors"
        >
          <span class="text-3xl mb-4">🏆</span>
          <h3 class="font-bold uppercase text-xs tracking-widest mb-2">
            Prestigio
          </h3>
          <p class="text-sm text-zinc-500">
            Essere presenti in eventi partecipati e riconosciuti.
          </p>
        </div>
        <div
          class="card bg-white border border-zinc-200 shadow-sm p-8 hover:border-[#ff6f00] transition-colors"
        >
          <span class="text-3xl mb-4">📍</span>
          <h3 class="font-bold uppercase text-xs tracking-widest mb-2">
            Territorio
          </h3>
          <p class="text-sm text-zinc-500">
            Creare un legame autentico con l'area locale.
          </p>
        </div>
      </div>
    </section>

    <section class="max-w-4xl mx-auto px-6 py-24">
      <h3 class="text-3xl font-black uppercase mb-10 tracking-tighter italic">
        Visibilità per gli sponsor
      </h3>
      <div class="space-y-4">
        <div
          class="flex items-center gap-6 p-6 bg-white rounded-2xl shadow-sm border border-zinc-100"
        >
          <div class="bg-zinc-100 p-4 rounded-full text-2xl">👍</div>
          <p class="font-bold text-lg">
            Logo su locandine, materiale promozionale e citazioni sui social
            ufficiali.
          </p>
        </div>
        <div
          class="flex items-center gap-6 p-6 bg-white rounded-2xl shadow-sm border border-zinc-100"
        >
          <div class="bg-zinc-100 p-4 rounded-full text-2xl">📅</div>
          <p class="font-bold text-lg">
            Presenza durante gli eventi (banner, stand e ringraziamenti sul
            palco).
          </p>
        </div>
        <div
          class="flex items-center gap-6 p-6 bg-white rounded-2xl shadow-sm border border-zinc-100"
        >
          <div class="bg-zinc-100 p-4 rounded-full text-2xl">✔️</div>
          <p class="font-bold text-lg">Collaborazioni personalizzate.</p>
        </div>
      </div>
    </section>

    <section
      class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-6"
    >
      <div
        class="bg-zinc-900 rounded-[3rem] p-12 text-white flex flex-col justify-between"
      >
        <div>
          <h4
            class="text-orange-500 uppercase tracking-widest font-bold text-xs mb-4"
          >
            Fascia di Investimento
          </h4>
          <h2 class="text-5xl font-black">DA 200€ A 1000€</h2>
        </div>
        <p class="text-zinc-500 mt-8">
          Fasce di partecipazione flessibili per ogni realtà.
        </p>
      </div>

      <div class="bg-[#ff6f00] rounded-[3rem] p-12 text-white">
        <h4
          class="text-orange-900 uppercase tracking-widest font-bold text-xs mb-6"
        >
          Spazi Pubblicitari
        </h4>
        <ul class="text-xl font-bold space-y-4 italic">
          <li>— PROIEZIONE LOGO SUL PALCO</li>
          <li>— SPAZIO PER 1 O PIU' STRISCIONI</li>
          <li>— PROMOZIONE ONLINE E SOCIAL</li>
          <li>— STAND IN LOCO</li>
        </ul>
      </div>
    </section>

    <section class="max-w-4xl mx-auto px-6 py-32 text-center">
      <div
        class="bg-white border-2 border-dashed border-zinc-200 rounded-[2rem] p-12"
      >
        <h3 class="text-2xl font-bold mb-6">
          Contattati per qualsiasi richiesta!
        </h3>
        <p class="text-lg text-zinc-600 mb-10 leading-relaxed">
          "I dettagli verranno definiti insieme, costruendo una proposta su
          misura per valorizzare al meglio il partner."
        </p>
        <a
          href="mailto:info@gerusco.it?subject=Sponsorizzazione Gerusco"
          class="btn btn-lg bg-[#ff6f00] hover:bg-zinc-900 border-none text-white px-10 rounded-full transition-all shadow-xl shadow-orange-100"
        >
          Contattaci ora
        </a>
      </div>
    </section>
  </div>
</Layout>
