---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import papero from "../assets/papero_cerchio.png";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";
---

<Layout title="Page not found">
  <div
    class="flex flex-col items-center justify-center min-h-[60vh] text-center px-6"
  >
    <PageHeader
      title="pagina inesistente"
      highlight="404"
      subtitle="La pagina che stai cercando non esiste"
    />
    <Button href="/"> ← Torna alla home </Button>

    <Image src={papero} alt="papero" />
  </div>
</Layout>
