      </div>
    </section>

    <section class="max-w-4xl mx-auto px-6 py-20 text-center">
      <h2
        class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-zinc-400"
      >
        Ci vediamo al Gerusco!
      </h2>
    </section>
  </main>
</Layout>
