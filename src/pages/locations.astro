---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";

// Dati delle location (puoi spostarli in un file .json esterno se preferisci)
const locations = [
  {
    nome: "Festa del Gerusco, Cura & Bea",
    descrizione: "Il cuore pulsante di Gerusco.",
    indirizzo:
      "Parco villa Terzaghi - Via San Giovanni 39 - Robecco sul Naviglio (MI)",
    mapsUrl: "https://maps.app.goo.gl/vBPU6TVxbgMTPeTd7",
    tipo: "Concerti - cibo - festival",
    parcheggi: [
      {
        nome: "Parcheggio Cimitero",
        info: "Non custodito, all' aperto. Gratuito. 6 minuti a piedi",
        maps: "https://maps.app.goo.gl/wiygYrRjXXLstuCn9",
      },
      {
        nome: "Piazzale del Mercato",
        info: "Non custodito, all' aperto. Gratuito.  8 minuti a piedi",
        maps: "https://maps.app.goo.gl/5o8MFsqT5Ct7rHtA7",
      },
    ],
  },
  {
    nome: "Gerusco Street Food Festival",
    descrizione: "Zona dedicata allo street food.",
    indirizzo: "Parco Borgo Archinto - Robecco sul Naviglio (MI)",
    mapsUrl: "https://maps.app.goo.gl/vBPU6TVxbgMTPeTd7",
    tipo: "Streetfood - musica",
    parcheggi: [],
  },
  {
    nome: "RocktoberFest",
    descrizione: "Festival in stile bavarese.",
    indirizzo:
      "Tendostruttura Comunale Cav. Angelo Mantegazzini - Via San Giovanni 39 - Robecco sul Naviglio (MI)",
    mapsUrl: "https://maps.app.goo.gl/UjDWpUqgy9s3XWkF9",
    tipo: "Pretzel - stinco - litro",
    parcheggi: [
      {
        nome: "Parcheggio Cimitero",
        info: "Non custodito, all' aperto. Gratuito. 6 minuti a piedi",
        maps: "https://maps.app.goo.gl/wiygYrRjXXLstuCn9",
      },
      {
        nome: "Piazzale del Mercato",
        info: "Non custodito, all' aperto. Gratuito.  8 minuti a piedi",
        maps: "https://maps.app.goo.gl/5o8MFsqT5Ct7rHtA7",
      },
    ],
  },
];
---

<Layout title="Dove trovarci - Gerusco">
  <main class="bg-zinc-50 min-h-screen pb-20">
    <section class="bg-white py-20 px-6 border-b border-zinc-200">
      <div class="max-w-5xl mx-auto text-center">
        <h1
          class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-6"
        >
          Come <span class="text-[#ff6f00]">Arrivare</span>
        </h1>
        <p class="text-xl text-zinc-500 max-w-2xl mx-auto font-medium">
          Tutti i punti di interesse del Gerusco in un unico posto. Seleziona la
          location e trova il parcheggio più vicino.
        </p>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-16 space-y-12">
      {
        locations.map((loc) => (
          <div class="group bg-white rounded-[2.5rem] border border-zinc-200 shadow-sm overflow-hidden hover:shadow-xl transition-all duration-500">
            <div class="grid grid-cols-1 md:grid-cols-12">
              <div class="md:col-span-7 p-8 md:p-12 border-b md:border-b-0 md:border-r border-zinc-100">
                <div class="flex items-center gap-3 mb-4">
                  <span class="badge bg-zinc-900 text-white border-none uppercase text-[10px] font-bold px-3 py-4 tracking-widest">
                    {loc.tipo}
                  </span>
                </div>
                <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tighter mb-4 group-hover:text-[#ff6f00] transition-colors">
                  {loc.nome}
                </h2>
                <p class="text-zinc-500 mb-8 leading-relaxed">
                  {loc.descrizione}
                </p>

                <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
                  <Button
                    href={loc.mapsUrl}
                    variant="primary"
                    class="gap-2 w-full sm:w-auto"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                        <circle cx="12" cy="10" r="3" />
                      </>
                    </svg>
                    Vai alla Location
                  </Button>
                  <span class="text-xs font-bold text-zinc-400 uppercase tracking-widest px-2">
                    {loc.indirizzo}
                  </span>
                </div>
              </div>

              <div class="md:col-span-5 p-8 md:p-12 bg-zinc-50/50">
                <h3 class="text-sm font-black uppercase tracking-[0.2em] text-zinc-400 mb-6 flex items-center gap-2">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <rect width="18" height="18" x="3" y="3" rx="2" />
                      <path d="M9 17V7h4a3 3 0 0 1 0 6H9" />
                    </>
                  </svg>
                  Parcheggi Consigliati
                </h3>

                <div class="space-y-6">
                  {loc.parcheggi.map((park) => (
                    <div class="relative pl-6 border-l-2 border-zinc-200 hover:border-[#ff6f00] transition-colors">
                      <h4 class="font-bold text-zinc-900 leading-none mb-2">
                        {park.nome}
                      </h4>
                      <p class="text-sm text-zinc-500 mb-3">{park.info}</p>
                      <a
                        href={park.maps}
                        target="_blank"
                        class="text-[10px] font-black uppercase tracking-widest text-[#ff6f00] hover:text-zinc-900 flex items-center gap-1"
                      >
                        Apri su Maps ↗
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </section>

    <section class="max-w-3xl mx-auto px-6 py-10 text-center">
      <div
        class="p-8 bg-[#ff6f00] rounded-[2rem] text-white shadow-2xl shadow-orange-100"
      >
        <h3 class="text-2xl font-black uppercase tracking-tight mb-2">
          Consiglio Staff
        </h3>
        <p class="font-medium opacity-90">
          Gerusco è un evento partecipatissimo! Cercate di arrivare in anticipo!
          Per qualsiasi informazione non esitare a contattarci!.
        </p>
      </div>
    </section>
  </main>
</Layout>
