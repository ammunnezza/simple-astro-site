---
import Layout from "../layouts/Layout.astro";
import Title from "../components/Title.astro";
import fontanella1 from "../assets/per-il-paese/fontanella1.jpg";
import fontanella2 from "../assets/per-il-paese/fontanella2.jpg";
import fontanella3 from "../assets/per-il-paese/fontanella3.jpg";
import Carousel from "../components/Carousel.astro";
import PageHeader from "../components/PageHeader.astro";

const images = [fontanella1.src, fontanella2.src, fontanella3.src];
---

<Layout title="Per il paese">
  <PageHeader title="Per il paese" highlight="paese" />

  <Title
    title="FULVIO COLOMBO"
    subtitle="Donazione di una fontanella per la nostra comunità"
    align="center"
    tag="in memoria del nostro caro"
  />
  <!--div class="py-20 px-6">
  <Carousel 
    images={images} 
    autoplay={true} 
    interval={4000} 
    class="max-w-5xl mx-auto h-[600px]" 
  />
</div-->

  <div class="py-10">
    <Carousel images={images} class="max-w-md mx-auto h-100" />

    <hr
      id="parco-giochi"
      class="my-12 h-px border-t-0 bg-transparent bg-gradient-to-r from-transparent via-zinc-300 to-transparent opacity-50"
    />

    <Title
      title="PROGETTO PARCO GIOCHI"
      subtitle="Un progetto per il futuro del paese"
      tag="un luogo di incontro, socialità e crescita."
      align="center"
    />

    <section class="max-w-4xl mx-auto px-6 py-20">
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="flex-1">
          <h2
            class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-none mb-6"
          >
            Un Progetto <span class="text-[#ff6f00]">Concreto</span>
          </h2>
          <p class="text-xl text-zinc-600 leading-relaxed font-medium">
            Stiamo attivando un progetto duraturo per la comunità: la
            realizzazione di un
            <span
              class="text-zinc-900 font-bold text-2xl md:text-3xl block mt-2"
              >Nuovo parco giochi polifunzionale.</span
            >
          </p>

          <p class="text-zinc-500 italic">
            "Questa collocazione lo renderebbe uno spazio centrale, sicuro e
            facilmente accessibile per famiglie, bambini e comunità."
          </p>
        </div>

        <div
          class="flex-1 bg-white p-8 md:p-10 rounded-[2.5rem] border border-zinc-100 shadow-xl shadow-zinc-100/50 relative overflow-hidden"
        >
          <h3
            class="text-xs font-black uppercase tracking-[0.2em] text-[#ff6f00] mb-8"
          >
            Posizione Strategica
          </h3>

          <ul class="space-y-6">
            {
              [
                {
                  text: "Adiacente alla scuola materna",
                  icon: "M22 10v6M2 10v6M12 4v16M2 10l10-6 10 6",
                },
                {
                  text: "Vicino ad ambulatori pediatrici",
                  icon: "M19 14c1.49 0 2.5-1.01 2.5-2.5S20.49 9 19 9s-2.5 1.01-2.5 2.5 1.01 2.5 2.5 2.5zM5 14c1.49 0 2.5-1.01 2.5-2.5S6.49 9 5 9s-2.5 1.01-2.5 2.5S3.51 14 5 14z",
                },
                {
                  text: "A ridosso dell’area feste / tensostruttura",
                  icon: "M12 3l8 4.5V16.5L12 21l-8-4.5V7.5L12 3z",
                },
              ].map((item) => (
                <li class="flex items-start gap-4 group">
                  <div class="flex-shrink-0 w-10 h-10 bg-orange-50 text-[#ff6f00] rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d={item.icon} />
                    </svg>
                  </div>
                  <span class="text-lg font-bold text-zinc-900 leading-tight pt-1">
                    {item.text}
                  </span>
                </li>
              ))
            }
          </ul>

          <div
            class="absolute -bottom-6 -right-6 text-zinc-50 opacity-50 select-none"
          >
            <svg
              width="120"
              height="120"
              viewBox="0 0 24 24"
              fill="currentColor"
              ><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"
              ></path></svg
            >
          </div>
        </div>
      </div>
      <div
        class="mt-20 text-center max-w-3xl mx-auto border-t border-zinc-100 pt-12"
      >
        <p
          class="text-2xl md:text-3xl font-medium text-zinc-900 leading-tight mb-10"
        >
          Il parco giochi non sarà solo un’area ludica, ma un <span
            class="text-[#ff6f00] font-black italic">luogo di incontro</span
          >, socialità e crescita.
        </p>

        <div
          class="bg-zinc-900 rounded-[2.5rem] p-8 md:p-12 text-white relative overflow-hidden group"
        >
          <div
            class="absolute top-0 right-0 w-32 h-32 bg-[#ff6f00] opacity-10 rounded-full -mr-16 -mt-16 group-hover:scale-110 transition-transform duration-700"
          >
          </div>

          <p class="text-lg md:text-xl font-bold leading-relaxed relative z-10">
            Investire in questo progetto significa investire nel <span
              class="text-[#ff6f00]">benessere delle famiglie</span
            >, nella qualità della vita e nel futuro del territorio.
          </p>

          <div class="mt-8 flex justify-center relative z-10">
            <div class="h-1 w-20 bg-white/20 rounded-full"></div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
